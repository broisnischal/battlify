# Battlify release secrets — template.
# Copy to .env (gitignored), fill in, then run: ./scripts/set-github-secrets.sh
#
# These feed the GitHub Actions "Release" workflow for Developer-ID signing and
# notarization. Until the Apple ones are filled, releases build UNSIGNED.

# Ephemeral CI keychain password — any random string. (Auto-generated in .env.)
KEYCHAIN_PASSWORD=

# Developer ID Application certificate exported as .p12, base64-encoded:
#   base64 -i DeveloperID.p12 | tr -d '\n'
DEVELOPER_ID_CERT_P12_BASE64=
# The password you set when exporting the .p12:
DEVELOPER_ID_CERT_PASSWORD=

# App Store Connect API key (role: Developer) for notarization:
NOTARY_KEY_ID=
NOTARY_ISSUER_ID=
# The AuthKey_XXXX.p8 file, base64-encoded:
#   base64 -i AuthKey_XXXX.p8 | tr -d '\n'
NOTARY_KEY_P8_BASE64=

# PAT used by the "Update appcast feed" workflow to write the update feed in the
# broisnischal/battlify-releases repo (the default CI token can't reach it).
# Create a FINE-GRAINED PAT scoped to ONLY that repo with Contents: Read and write:
#   https://github.com/settings/personal-access-tokens/new
RELEASES_TOKEN=
